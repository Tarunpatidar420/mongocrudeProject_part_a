<% layout("layouts/boilerplate")%>
<body>
    <h3>create new route</h3>
    <form method="post" action="/listen">
        <input type="text" name="arr[title]" placeholder="enter title">
        <br>
        <textarea name="arr[description]"  rows="8" cols="30"></textarea>
        <br>
        <input type="number" name="arr[price]" placeholder="price">
        <br>
        <input type="text" placeholder="location" name="arr[location]">
        <br>
        <input type="text" name="arr[country]" placeholder="country">
        <br>
        <button>submit</button>
    </form>
</body>
