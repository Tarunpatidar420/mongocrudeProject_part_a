<% layout("layouts/boilerplate")%>
<body>
    <h3>Edit</h3>
    <form method="post" action="/listen/<%=yourdata._id%>?_method=PUT">
        <label for="name">Name</label>
        <input type="text" name="arr[title]" value="<%=yourdata.title %>">
        <br>
    <label for="description">Description</label>
        <textarea name="arr[description]"  rows="5" cols="40"><%= yourdata.description%></textarea>
        <br>
        <label for="price">price</label>
        <input type="number" name="arr[price]" value="<%=yourdata.price %>">
        <br>
        <label for="location">Location</label>
        <input type="text" value="<%=yourdata.location %>" name="arr[location]">
        <br>
        <label for="country">Country</label>
        <input type="text" name="arr[country]" value="<%=yourdata.country %>">
        <br>
        <label>Image URL</label>

<input type="text"name="arr[image][url]"value="<%= yourdata.image.url %>">
<br><br>
        <button class="btn btn-dark">submit</button>
    </form>
</body>
